# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
VITE_APP_NAME=SIC (Angrisani)
VITE_ENV=development

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
# Base URL for real API backend (FastAPI, Django, etc.)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Set to "true" to use MSW mock API instead of a real backend
VITE_USE_MOCK_API=true
VITE_MOCK_SCENARIO=demo

# ─────────────────────────────────────────────
# Observability — Sentry
# ─────────────────────────────────────────────
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=
